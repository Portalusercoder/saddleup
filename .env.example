# =============================================================================
# SaddleUp — local development (.env.example)
# Copy to .env.local and fill in values:  cp .env.example .env.local
# =============================================================================

# --- Required (auth + dashboard) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Recommended (server-side Supabase, emails, admin tasks) ---
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Optional: signup security (Cloudflare Turnstile) ---
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# --- Optional: email (Resend) ---
# RESEND_API_KEY=
# FROM_EMAIL=Saddle Up <onboarding@resend.dev>
# RESEND_FROM=Saddle Up <onboarding@resend.dev>
# CONTACT_TO_EMAIL=you@example.com

# --- Optional: Stripe billing ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_STARTER_PRICE_ID=
# STRIPE_STABLE_PRICE_ID=

# --- Required in production: password reset HMAC (long random string) ---
# PASSWORD_RESET_SECRET=

# --- Optional: platform admin (comma-separated emails) ---
# ADMIN_EMAILS=you@example.com

# --- Optional: rate limiting (Upstash Redis) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Optional: AI workload suggestions ---
# OPENAI_API_KEY=

# --- Optional: analytics & monitoring ---
# NEXT_PUBLIC_MIXPANEL_TOKEN=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=

# --- Optional: cron / internal jobs ---
# CRON_SECRET=

# --- Optional: CORS (comma-separated origins) ---
# ALLOWED_ORIGINS=http://localhost:3000
